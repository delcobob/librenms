###############################################################################
# LibreNMS Application Environment Variables
# Shared by all LibreNMS containers (web, dispatcher, syslog, snmptrapd)
#
# Full reference: https://github.com/librenms/docker
###############################################################################

# =============================================================================
# Memory & Performance
# =============================================================================
MEMORY_LIMIT=256M
MAX_INPUT_VARS=1000
UPLOAD_MAX_SIZE=30M
OPCACHE_MEM_SIZE=128

# =============================================================================
# SNMP Settings
# Update the community string to match your network devices
# =============================================================================
LIBRENMS_SNMP_COMMUNITY=public

# =============================================================================
# Poller / Discovery Settings
# =============================================================================
LIBRENMS_POLLER_THREADS=16
LIBRENMS_POLLER_INTERVAL=300

# =============================================================================
# Weathermap (set to true to enable the Weathermap plugin)
# =============================================================================
LIBRENMS_WEATHERMAP=false

# =============================================================================
# Cron Scheduling
# =============================================================================
CRON_DISCOVERY_ENABLE=true
CRON_DAILY_ENABLE=true
CRON_ALERTS_ENABLE=true
CRON_BILLING_ENABLE=true
CRON_BILLING_CALCULATE_ENABLE=true
CRON_CHECK_SERVICES_ENABLE=true
CRON_POLLER_ENABLE=true

# =============================================================================
# Log Rotation (in days)
# =============================================================================
LOG_IP_VAR=remote_addr

# =============================================================================
# Real IP (if behind a reverse proxy, set the trusted proxy header)
# =============================================================================
#REAL_IP_FROM=172.20.0.0/24
#REAL_IP_HEADER=X-Forwarded-For

# =============================================================================
# SMTP / Mail Settings (for alert notifications via email)
# =============================================================================
#LIBRENMS_MAILER_DRIVER=smtp
#LIBRENMS_MAILER_HOST=smtp.example.com
#LIBRENMS_MAILER_PORT=587
#LIBRENMS_MAILER_USER=
#LIBRENMS_MAILER_PASSWORD=
#LIBRENMS_MAILER_ENCRYPTION=tls
#LIBRENMS_MAILER_FROM_ADDRESS=librenms@example.com
#LIBRENMS_MAILER_FROM_NAME=LibreNMS
